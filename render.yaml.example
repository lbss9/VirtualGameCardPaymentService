# This service runs as a free Render Web Service with a background SQS consumer.
# Free web services may sleep when inactive; for production, use a paid worker.
services:
  - type: web
    name: virtualgamecard-payment-service
    runtime: docker
    plan: free
    region: oregon
    healthCheckPath: /healthz
    autoDeploy: true
    envVars:
      - key: DOTNET_ENVIRONMENT
        value: Production
      - key: Sqs__Enabled
        value: true
      - key: Sqs__Region
        value: us-east-2
      - key: Sqs__PaymentRequestedQueueUrl
        value: https://sqs.us-east-2.amazonaws.com/212263949491/vgc-payment-requested
      - key: Sqs__PaymentApprovedQueueUrl
        value: https://sqs.us-east-2.amazonaws.com/212263949491/vgc-payment-approved
      - key: Sqs__PaymentSimulationDelaySeconds
        value: 30
      - key: AWS_ACCESS_KEY_ID
        sync: false
      - key: AWS_SECRET_ACCESS_KEY
        sync: false
